# Example environment variables for LeadBridge
# Copy to .env and fill values

MONGO_URI=mongodb+srv://leadbridge_user:YourPassword@leadmanager-cluster.w0gqduv.mongodb.net/leadbridge?retryWrites=true&w=majority
PAGE_ACCESS_TOKEN=your_page_access_token_here
VERIFY_TOKEN=your_webhook_verify_token_here
# Optional for improved webhook security (recommended)
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

PORT=4000
